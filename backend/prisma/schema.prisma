generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}model Region {
  id         String      @id @default(uuid())
  name       String      @unique
  campuses   Campus[]
  candidates Candidate[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Campus {
  id        String   @id @default(uuid())
  name      String
  regionId  String
  region    Region   @relation(fields: [regionId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Candidate {
  id        String            @id
  full_name String
  gender    String
  region    String
  campus    String
  major     String
  ukt       String?
  home_visit_status String? @default("pending")
  pantukhir_status  String?
  regionRel Region?           @relation(fields: [region], references: [name], onDelete: SetNull)
  schedules Schedule[]
  results   HomeVisitResult[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model Visitor {
  id        String            @id
  name      String
  role      String            @default("fasil")
  schedules Schedule[]
  results   HomeVisitResult[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model Instrument {
  id         String   @id @default(uuid())
  pertanyaan String
  urutan     Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Schedule {
  id            String    @id @default(uuid())
  candidateId   String
  visitorId     String
  schedule_date String
  schedule_time String?
  status        String    @default("scheduled")
  notes         String?
  candidate     Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  visitor       Visitor   @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model HomeVisitResult {
  id          String    @id @default(uuid())
  candidateId String
  fasilId     String
  submittedAt DateTime  @default(now())
  answers     Json
  score       Float
  status      String
  notes       String?
  photos      Json?
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  visitor     Visitor   @relation(fields: [fasilId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}


